# Copy to .env and fill in

# Slack bot token (xoxb-...) with chat:write scope, and your member ID for DMs
SLACK_BOT_TOKEN=
SLACK_USER_ID=

# JSearch via RapidAPI (covers LinkedIn + Indeed + Glassdoor postings)
# Free tier: 100 requests/month. You already have one from job-monitor.
JSEARCH_API_KEY=

# Phase 2 only — Claude API for borderline-match explanations
ANTHROPIC_API_KEY=
